le\n        ...GamesDownloadFragment\n        contentAdvisory {\n            certificationValue\n            maturityDescription\n        }\n        contentMetadata {\n            gameNumberOfPlayers {\n                label\n            }\n            duration {\n                label\n            }\n        }\n        primaryGenres {\n            edges {\n                node {\n                    genreId\n                    name\n                }\n            }\n        }\n        contextualSynopsis(context: { uiContext: ODP }) {\n            evidenceKey\n            text\n        }\n        lodpTaglineMessage: taglineMessage(\n            taglineRequest: { typedUiContext: LOGGED_OUT_DP }\n        ) {\n            tagline\n        }\n    }\n":r.GamesMetadataFragmentFragmentDoc,"\n    fragment GamesBillboardVideoFragment on Supplemental {\n        videoId\n        __typename\n        ...SupplementalPlayableVideoFragment\n    }\n":r.GamesBillboardVideoFragmentFragmentDoc,"\n    fragment GamesLodpHero on Game {\n        gameId\n        ...GamesHeroContentFragment\n        title\n        heroImageSmall: artwork(\n            params: {\n                format: WEBP\n                artworkType: BILLBOARD\n                dimension: { width: 960 }\n                features: {\n                    nonMemberBranding: true\n                    fallbackStrategy: STORY_ART\n                }\n            }\n        ) {\n            url\n        }\n        heroImageMedium: artwork(\n            params: {\n                format: WEBP\n                artworkType: BILLBOARD\n                dimension: { width: 1280 }\n                features: {\n                    nonMemberBranding: true\n                    fallbackStrategy: STORY_ART\n                }\n            }\n        ) {\n            url\n        }\n        heroImageLarge: artwork(\n            params: {\n                format: WEBP\n                artworkType: BILLBOARD\n                dimension: { width: 1920 }\n                features: {\n                    nonMemberBranding: true\n                    fallbackStrategy: STORY_ART\n                }\n            }\n        ) {\n            url\n        }\n\n        # promoVideo is the reliable source for the hero trailer video.\n        # supplementalVideosList was previously used but returns empty for\n        # mobile games, while promoVideo works for both mobile and cloud.\n        # videoId and __typename at the video level are required by Apollo\n        # cache normalization (keyFields).\n        promoVideo(context: { uiContext: BROWSE, supportsPlaygraph: true }) {\n            id\n            video {\n                __typename\n                videoId\n                ... on Supplemental {\n                    title\n                    videoId\n                    ...GamesBillboardVideoFragment\n                }\n            }\n        }\n    }\n":r.GamesLodpHeroFragmentDoc,"\n    fragment GamesHeroContentFragment on Game {\n        gameId\n        unifiedEntityId\n        __typename\n        title\n        gameStudioImage: artwork(\n            params: {\n                artworkType: BRAND_LOGO_CROPPED\n                dimension: { height: 48 }\n                features: { tone: LIGHT, nonMemberBranding: true }\n            }\n        ) {\n            url\n        }\n        iconImage: artwork(\n            params: {\n                format: WEBP\n                artworkType: APP_ICON\n                dimension: { width: 200, height: 200 }\n                features: {\n                    boxartForceUnbranded: true\n                    performNewContentCheck: false\n                    nonMemberBranding: true\n                }\n            }\n        ) {\n            url\n        }\n        cloudGameTitleWithLogo: artwork(\n            params: {\n                artworkType: LOGO_BRANDED_STACKED\n                format: WEBP\n                features: {\n                    brandLogoAlign: CENTER\n     