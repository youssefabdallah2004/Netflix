ery SecondaryDemoCollectionPage($profileGuid: ID) {\n        currentProfile {\n            guid\n            name\n        }\n        growthCollectEmailConsentInfo(\n            contextInput: {\n                growthInputNode: { inputUserJourneyNode: UPDATE_PROFILE_EMAIL }\n            }\n            collectEmailConsentInfoInput: {\n                collectEmailType: PROFILE_ADD_EMAIL\n                profileGuid: $profileGuid\n            }\n        ) {\n            ...SecondaryProfileDemoFragment\n        }\n    }\n":r.SecondaryDemoCollectionPageDocument,"\n    mutation GrowthCreateMfaChallenge(\n        $createMfaChallengeInput: GrowthCreateMfaChallengeInput!\n        $contextInput: GrowthContextInput!\n    ) {\n        growthCreateMfaChallenge(\n            createMfaChallengeInput: $createMfaChallengeInput\n            contextInput: $contextInput\n        ) {\n            ...GrowthMutationResponseFragment\n        }\n    }\n":r.GrowthCreateMfaChallengeDocument,"\n    fragment Artwork on Image {\n        key\n        url\n        width\n        height\n        available\n        status\n        focalPoint {\n            x\n            y\n        }\n    }\n":r.ArtworkFragmentDoc,"\n    fragment Bookmark on Viewable {\n        ... on Video {\n            videoId\n        }\n\n        runtimeSec\n        bookmark {\n            position\n        }\n    }\n":r.BookmarkFragmentDoc,"\n    fragment GrowthMutationResponseFragment on GrowthMutationResponse {\n        __typename\n        ... on GrowthNextNode {\n            userJourneyNodeName\n            treatment\n            intent {\n                value\n                category\n            }\n        }\n        ... on GrowthMutationError {\n            errorCode\n            errorType\n            errorMessage\n            debugInfo {\n                key\n                value\n            }\n            redirectNode {\n                userJourneyNodeName\n                treatment\n                intent {\n                    value\n                    category\n                }\n            }\n        }\n\n        ... on GrowthMutationTask {\n            id\n            pollingInterval\n        }\n    }\n":r.GrowthMutationResponseFragmentFragmentDoc,"\n    fragment LiveEventMetadata on LiveEvent {\n        availabilityStartTime\n        timeWindow {\n            # use availabilityStartTime instead of startTime here\n            endTime\n        }\n        event {\n            ... on Episode {\n                videoId\n                isAvailable\n            }\n\n            ... on Movie {\n                videoId\n                isAvailable\n            }\n        }\n    }\n":r.LiveEventMetadataFragmentDoc,"\n    fragment LiveVideo on Video {\n        videoId\n\n        ... on Show {\n            nextLiveEvent {\n                ...LiveEventMetadata\n            }\n        }\n\n        ... on LiveEventViewable {\n            liveEvent {\n                ...LiveEventMetadata\n            }\n        }\n    }\n":r.LiveVideoFragmentDoc,"\n    fragment LiveEventTaglines on Video {\n        videoId\n\n        ... on LiveEventInRealTimeWindow {\n            allTaglineMessagesByLiveState(\n                taglineRequest: {\n                    typedUiContext: $textEvidenceUiContext\n                    supportsMessageBadging: true\n                }\n            ) {\n                taglineMessages {\n                    tagline\n                    typedClassification\n                    badgeDate\n                    badgePrefix\n                }\n                state\n            }\n        }\n    }\n":r.LiveEventTaglinesFragmentDoc,"\n    fragment VideoPlaylist on Video {\n        videoId\n        unifiedEntityId\n\n        isPlayable\n        isAvailable\n        unplayableCauses\n\n        isInPlaylist\n        isInRemindMeList\n        isInRollingRemindersList\n        hasRecurringReleases\n        playlistActions\n    }\n":r.VideoPlaylistFragmentDoc,"\n    fragment GamePlaylist on Game {\n        gameId\n        unifiedEntityId\n\n        isPlayable\n        isInPlaylist\n        isInRemindMeList\n        gamePlaylistActions: playlistActions\n    }\n":r.GamePlaylistFragmentDoc,"\n    mutation AddToPlaylist($entityId: ID!, $trackId: ID, $signature: String) {\n        addEntityToPlaylist(\n            input: {\n                entityId: $entityId\n                trackId: $trackId\n                signature: $signature\n            }\n        ) {\n            entity {\n                ... on Video {\n                    videoId\n                    title\n                    isInPlaylist\n                    isInRemindMeList\n                }\n                ... on Game {\n                    gameId\n                    gamePlaylistActions: playlistActions\n                    isInPlaylist\n                }\n            }\n        }\n    }\n":r.AddToPlaylistDocument,"\n    mutation RemoveFromPlaylist(\n        $entityId: ID!\n        $trackId: ID\n        $signature: String\n    ) {\n        removeEntityFromPlaylist(\n            input: {\n                entityId: $entityId\n                trackId: $trackId\n                signature: $signature\n            }\n        ) {\n            entity {\n                ... on Video {\n                    videoId\n                    title\n                    isInPlaylist\n                    isInRemindMeList\n                }\n                ... on Game {\n                    gameId\n                    gamePlaylistActions: playlistActions\n                    isInPlaylist\n                }\n            }\n        }\n    }\n":r.RemoveFromPlaylistDocument,"\n    mutation AddReminder($entityId: ID!, $signature: String, $trackId: ID) {\n        addUnifiedEntityToRemindMe(\n            input: {\n                unifiedEntityId: $entityId\n                signature: $signature\n                trackId: $trackId\n            }\n        ) {\n            ... on Video {\n                videoId\n                playlistActions\n                isInPlaylist\n                isInRemindMeList\n            }\n            ... on Game {\n                gameId\n                gamePlaylistActions: playlistActions\n                isInPlaylist\n                isInRemindMeList\n            }\n        }\n    }\n":r.AddReminderDocument,"\n    mutation RemoveReminder($entityId: ID!, $signature: String, $trackId: ID) {\n        removeUnifiedEntityFromRemindMe(\n            input: {\n                unifiedEntityId: $entityId\n                signature: $signature\n                trackId: $trackId\n            }\n        ) {\n            ... on Video {\n                videoId\n                playlistActions\n                isInPlaylist\n                isInRemindMeList\n            }\n            ... on Game {\n                gameId\n                gamePlaylistActions: playlistActions\n                isInPlaylist\n                isInRemindMeList\n            }\n        }\n    }\n":r.RemoveReminderDocument,"\n    mutation AddRollingReminders(\n        $entityId: ID!\n        $signature: String\n        $trackId: ID\n    ) {\n        addUnifiedEntityToRollingReminders(\n            input: {\n                unifiedEntityId: $entityId\n                signature: $signature\n                trackId: $trackId\n            }\n        ) {\n            ... on Video {\n                videoId\n                playlistActions\n                isInPlaylist\n                isInRollingRemindersList\n                hasRecurringReleases\n            }\n        }\n    }\n":r.AddRollingRemindersDocument,"\n    mutation RemoveRollingReminders(\n        $entityId: ID!\n        $signature: String\n        $trackId: ID\n    ) {\n        removeUnifiedEntityFromRollingReminders(\n            input: {\n                unifiedEntityId: $entityId\n                signature: $signature\n                trackId: $trackId\n            }\n        ) {\n            ... on Video {