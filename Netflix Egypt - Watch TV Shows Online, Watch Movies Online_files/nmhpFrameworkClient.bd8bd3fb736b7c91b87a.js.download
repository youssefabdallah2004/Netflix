oData {\n            browserTitle\n            descriptiveText\n            headline\n        }\n    }\n":r.LocpHeroMetadataFragmentDoc,"\n    query GamePlayableQuery($gameIds: [Int!]!) {\n        games(gameIds: $gameIds) {\n            unifiedEntityId\n            cloudReleaseState: releaseState(params: { gamePlatform: CLOUD })\n            iosReleaseState: releaseState(params: { gamePlatform: IOS })\n            androidReleaseState: releaseState(params: { gamePlatform: ANDROID })\n            isPlayable\n            deviceCategories\n        }\n    }\n":r.GamePlayableQueryDocument,"\n    query Videos($videoIds: [Int!]!) {\n        videos(videoIds: $videoIds) {\n            isPlayableOnAdsPlan\n            contentAdvisory {\n                maturityLevel\n            }\n            coreGenres {\n                edges {\n                    node {\n                        name\n                    }\n                }\n            }\n            hasOriginalTreatment\n            isAvailable\n            title\n            __typename\n            videoId\n            ... on Episode {\n                parentShow {\n                    videoId\n                }\n            }\n            personsActors: persons(roles: ACTOR) {\n                edges {\n                    node {\n                        name\n                    }\n                }\n            }\n            personsCreators: persons(roles: CREATOR) {\n                edges {\n                    node {\n                        name\n                    }\n                }\n            }\n            personsDirectors: persons(roles: DIRECTOR) {\n                edges {\n                    node {\n                        name\n                    }\n                }\n            }\n            ... on Season {\n                parentShow {\n                    videoId\n                }\n            }\n            ... on Supplemental {\n                ancestor {\n                    videoId\n                }\n            }\n            ... on Show {\n                artworkHero: artwork(\n                    params: {\n                        artworkType: STORY_ART\n                        format: PNG\n                        features: { nonMemberBranding: true }\n                    }\n                ) {\n                    url\n                }\n                artworkBillboard: artwork(\n                    params: {\n                        artworkType: BILLBOARD\n                        format: PNG\n                        features: {\n                            fallbackStrategy: STORY_ART\n                            nonMemberBranding: true\n                        }\n                    }\n                ) {\n                    url\n                }\n                shortSynopsis\n                seasons {\n                    totalCount\n                }\n            }\n            ... on Movie {\n                artworkHero: artwork(\n                    params: {\n                        artworkType: STORY_ART\n                        format: PNG\n                        features: { nonMemberBranding: true }\n                    }\n                ) {\n                    url\n                }\n                artworkBillboard: artwork(\n                    params: {\n                        artworkType: BILLBOARD\n                        format: PNG\n                        features: {\n                            fallbackStrategy: STORY_ART\n                            nonMemberBranding: true\n                        }\n                    }\n                ) {\n                    url\n                }\n                shortSynopsis\n            }\n        }\n    }\n":r.VideosDocument,"\n    mutation OAuth2Authorize($state: String, $codeChallenge: String) {\n        oAuth2Authorize(state: $state, codeChallenge: $codeChallenge) {\n            authorizationCode\n            state\n        }\n    }\n":r.OAuth2AuthorizeDocument,"\n    query GameDetailsQuery($gameIds: [Int!]!) {\n        games(gameIds: $gameIds) {\n            ...GamesLodpHero\n            ...GamesMoreDetailsFragment\n            ...GamesGallery\n            ...GamesMetadataFragment\n            ...GamesSEOMetadataFragment\n            ...GamesStructuredDataFragment\n            _id\n            unifiedEntityId\n            supportedLanguages\n            nGameImage: artwork(\n                params: {\n                    artworkType: BRAND_LOGO_CROPPED\n                    dimension: { height: 48 }\n                    features: {\n                        tone: LIGHT\n                        forceBrandLogo: N_GAMES\n                        nonMemberBranding: true\n                    }\n                }\n            ) {\n                url\n            }\n            qrIconImage: artwork(\n                params: {\n                    format: WEBP\n                    artworkType: APP_ICON\n                    dimension: { width: 150, height: 150 }\n                    features: {\n                        boxartForceUnbranded: true\n                        performNewContentCheck: false\n                        nonMemberBranding: true\n                    }\n                }\n            ) {\n                url\n            }\n            pageBackgroundImage: artwork(\n                params: {\n                    format: WEBP\n                    artworkType: BILLBOARD\n                    features: { nonMemberBranding: true }\n                }\n            ) {\n                url\n            }\n        }\n        growthPlans {\n            plans {\n                planId\n                price {\n                    priceInCents\n                    priceFormatted\n                }\n            }\n        }\n    }\n":r.GameDetailsQueryDocument,"\n    fragment GamesDownloadFragment on Game {\n        gameId\n        unifiedEntityId\n        iosInstallation {\n            appStoreId\n        }\n        androidInstallation 