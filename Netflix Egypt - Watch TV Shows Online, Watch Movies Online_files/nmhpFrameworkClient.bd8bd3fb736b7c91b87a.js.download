reen was rendered",ntl:{clientBehaviorConfig:{canBatch:!0,requiresEnhancedSecurity:!1}},type:"object",properties:{requestId:{type:"string"},screenName:{type:"string"},clcsRenditionId:{type:"string"},clcsSessionId:{type:"string"},screenVariantName:{type:"string"},abAllocations:{type:"string"},funnelName:{type:"string"}},required:["requestId","screenName","clcsRenditionId","clcsSessionId","funnelName"]},"netflix.ClientContext":{$schema:"http://json-schema.org/draft-07/schema#",title:"ClientContext",description:"",type:"object",properties:{loggerContext:{description:"Struct containing all information relating to the NTL logger",type:"object",properties:{loggerId:{description:"Unique id for the initialized logger",type:"string"}},required:["loggerId"]},appContext:{description:"Struct containing all information relating to the application",type:"object",properties:{streaming:{description:"Struct containing all information relating to the Netflix Streaming App",type:"object",properties:{appVersion:{description:"Version of the currently running streaming application. **This field may end up being temporary. Please log whatever version is most helpful to identify a specific build/tag/release of the client for observability/alerting purposes. There is future work to align on how NTL should log, manage, and track version information from clients.**",type:"string"},nrdVersions:{description:"*This is mostly illustrative and will be expanded upon in future iterations*",type:"object",properties:{nrdpVersion:{description:"",type:"string"},nrdJsVersion:{description:"",type:"string"}},required:["nrdpVersion"]}},required:["appVersion"]},application:{description:"Simplified enum representing which application this Event Record is coming from. This is an NTL specific concept with the field being passed from the client directly. Combine this field with **devicePlatform** to get the unique client application/code path that sent the payload.",type:"string",enum:["streaming","gaming","tudum","helpCenter","netspeed","obiwan","unknown"]}},required:["application"]},deviceContext:{description:"Struct containing all information relating to the device",type:"object",properties:{chipset:{description:"The processor reported by operating system",type:"string"},deviceModel:{description:"The model of the device",type:"string"},osVersion:{description:"The current operating system version",type:"string"},devicePlatform:{description:"Simplified enum representing which device platform this Event Record is coming from. This is an NTL specific concept with the field being passed from the client directly.",type:"string",enum:["android","iOS","tvui","web","ocga","tvOS","unknown"]},androidInfo:{description:"Struct containing all information relating specifically to android devices",type:"object",properties:{},required:[]},tvuiInfo:{description:"Struct containing all information relating specifically to television devices",type:"object",properties:{},required:[]},wwwInfo:{description:"Struct containing all information relating to web devices",type:"object",properties:{},required:[]},iOSInfo:{description:"Struct containing all information relating to iOS devices",type:"object",properties:{},required:[]}},required:["devicePlatform"]},schemaVersion:{description:"Which schema version of the client context is represented in the NTL payload.",type:"integer"},userInfo:{description:"Client-side data being tracked for the current Netflix user",type:"object",properties:{profileGuid:{description:"Represents a single profile with a guid. Safe to expose outside. **This should be updated by the client on profile changes**",type:"string"}},required:[]}},required:["loggerContext","appContext","deviceContext","schemaVersion"]},"netflix.DeliveryTestNtl":{$schema:"https://json-schema.org/draft/2020-12/schema",title:"DeliveryTestNtl",description:"Used to compare delivery capability of the CL logger and NTL logger used by client applications. This is the NTL version of that event.\n\nEach client should determine when the app should log this event. It should be neither too frequent (like Presented events) nor too infrequent. One suggestion is to log it whenever a DP is shown.",ntl:{clientBehaviorConfig:{canBatch:!0,requiresEnhancedSecurity:!1}},type:"object",properties:{willItBlend:{type:"boolean"},stringMap:{type:"object",additionalProperties:{type:"string"}}}},"netflix.FaqAccordionToggled":{$schema:"http://json-schema.org/draft-07/schema#",title:"FaqAccordionToggled",description:"",ntl:{clientBehaviorConfig:{canBatch:!0,requiresEnhancedSecurity:!1}},type:"object",properties:{viewName:{type:"string"},faqItemId:{type:"string"},action:{type:"string"}},required:["viewName","faqItemId","action"]},"netflix.HandledError":{$schema:"http://json-schema.org/draft-07/schema#",title:"HandledError",description:"Data about a handled error. Handled errors capture failures that have been accounted for. The location where the error is handled is already known, so there is no need for a call stack.\n\nThis is a replacement for one of the use cases of the CL ExceptionOccurred event.\nFor more details, see the [NTL: Events for Debugging](https://docs.google.com/document/d/1oqQr43_EEGYhDnrNPx629S6n7-y6h9iBmbKclC-kI8I/edit?tab=t.0) document.",type:"object",properties:{name:{description:"Name of the handled error.",type:"string"},message:{description:"A message describing the error.",type:"string"},location:{description:"The location where the error is handled.",type:"string"},level:{description:"The level of user impact or disruption caused by this error.\n- **fatal**: App session has failed, and a reload is required.\n- **disruption**: The user's journey is interrupted or the user experience is affected, but the app session is still usable. A retry, if available/possible, is likely to resolve it. Error dialogs are considered disruptions. Another example would be if the Continue Watching row failed to load.\n- **other**: All other types of errors, including ones where the user's journey is not interrupted or where impact is not fully known. For example, an error that results in a failed Lolomo genre row.",type:"string",enum:["disruption","fatal","other"]},data:{description:"Any additional metadata that can aid in debugging the error.\n\nIdeally, this type could have been a `Map<String, String/Number/Integer/Boolean/Object>`, but the schema only supports `Map<String, String>`. So, convert the values to strings, or JSON strings to preserve the type.",type:"object",additionalProperties:{type:"string"}},cause:{description:"The causal chain for the error. This can be the errors leading up to the handled error. Use the JSON string format for each individual array item.",type:"array",items:{type:"string"}}},required:["name"]},"netflix.HandledException":{$schema:"https://json-schema.org/draft/2020-12/schema",title:"HandledException",description:"Data about a handled exception. Handled exceptions capture unexpected failures in the app, where the call stack and/or component stack are vital for troubleshooting.\n\nThis is a replacement for one of the use cases of the CL ExceptionOccurred event.\nFor more details, see the [NTL: Events for Debugging](https://docs.google.com/document/d/1oqQr43_EEGYhDnrNPx629S6n7-y6h9iBmbKclC-kI8I/edit?tab=t.0) document.",type:"object",properties:{name:{description:"A name for the handled exception.",type:"string"},message:{description:"A message describing the error.",type:"string"},callStack:{description:"The call stack to help identify where the exception was thrown from.",type:"string"},componentStack:{description:"The component stack to help identify which UI component the exception occurred in.",type:"string"},level:{description:"The level of user impact or disruption caused by this exception.\n- **fatal**: App session has failed, and a reload is required.\n- **disruption**: The user's journey is interrupted or the user experience is affected, but the app session is still usable. A retry, if available/possible, is likely to resolve it. Error dialogs are considered disruptions. Another example would be an exception in the search page that results in a failure to load results.\n- **other**: All other types of errors, including ones where the user's journey is not interrupted or where impact is not fully known. For example, an exception that prevents an animation from running.",type:"string",enum:["disruption","fatal","other"]},data:{description:"Any additional metadata that can aid in debugging the exception.\n\nIdeally, this type could have been a `Map<String, String/Number/Integer/Boolean/Object>`, but the schema only supports `Map<String, String>`. So, convert the values to strings, or JSON strings to preserve the type.",type:"object",additionalProperties:{type:"string"}},cause:{description:"The causal chain for the error. This can be the errors leading up to the handled error. Use the JSON string format for each individual array item.",type:"array",items:{type:"string"}}},required:["name","callStack"]},"netflix.HendrixFieldAccess":{$schema:"http://json-schema.org/draft-07/schema#",title:"HendrixFieldAccess",description:"Represents a field access event for Hendrix/Woodstock fields.\n \nThis event is logged when a Hendrix field value is actually accessed (exposure)",ntl:{clientBehaviorConfig:{canBatch:!0,requiresEnhancedSecurity:!1}},type:"object",properties:{ruleSetName:{type:"string",description:"Name of RuleSet, for ABlaze Properties this is the fully-qualified name, e.g. (com.netflix.properties.foo)"},fieldName:{type:"string",description:"The specific field name within the ruleset."},ruleSetVersion:{type:"string",description:"Version identifier for the ruleset at the time of evaluation."},source:{type:"string",enum:["live","fallback","override"],"ntl-enum-descriptions":{live:"Value retrieved from Hendrix/Woodstock in real-time",fallback:"Used hardcoded fallback (Woodstock unavailable or kill switch active)",override:"Value was overridden via dev tools or URL params (DEV ONLY)"},description:"Indicates where the property value was sourced from"}},required:["ruleSetName","fieldName","ruleSetVersion"]},"netflix.MerchableEntityClicked":{$schema:"http://json-schema.org/draft-07/schema#",title:"MerchableEntityClicked",description:"Indicates the user clicked or tapped or activated on a merchable entity like a BoxArt, this may or may not trigger subsequent Actions.",type:"object",properties:{view:{description:"Name of the engaged view if any",type:"string"},trackingInfo:{description:"tracking information",type:"string"}},required:["view","trackingInfo"]},"netflix.Navigate":{$schema:"http://json-schema.org/draft-07/schema#",title:"Navigate",description:'Indicates that the user-interface is moving from one logical navigation "location" (e.g., page, screen, area) to another, "pushing" or "popping" location(s) against the navigation "stack".\n\nNavigate does not appear during the initial application bootstrap. It only appears in response to user actions after the app has loaded.\n\nExisting Use Cases\n2024-05-17 - Navigate and RenderNavigationLevel are the pair of events that define the start and the end of Canvas TTR, i.e. Time to Render when navigating within the app. To learn more about App QoE metrics see here\n',type:"object",properties:{command:{description:"Intent that resulted in logging this Action. This is a newly added field to support simplified schema. In order to be backwards compatible it is currently an optional value, however once all the logging follows simplified schema specification this will be made a required property\n",type:"string"},parentView:{description:"Name of the engaged parent view that triggered this action e.g. if more than one button with the same view name was clicked that triggered this action then the parent view name assigned to the button should be used here to distinguish between the two. However this field is optional and should only be used when the view by itself leads to ambiguity of where in the UI this action was triggered from.",type:"string"},view:{description:"Name of the engaged view that triggered this action e.g. if a button was clicked that triggered this action then the view name assigned to the button should be used here. However this field is optional, if this action was triggered without engaging any view (e.g. a button or a boxArt) then this field should not be set.",type:"string"},trackingInfo:{description:"Server-defined tracking information, if applicable.",type:"string"}},required:[]},"netflix.TestEventSecure":{$schema:"http://json-schema.org/draft-07/schema#",title:"TestEventSecure",description:"",ntl:{clientBehaviorConfig:{canBatch:!0,requiresEnhancedSecurity:!0}},type:"object",properties:{useTLS:{type:"boolean"},deviceId:{type:"string"},browserName:{type:"string"},browserVersion:{type:"string"}},required:["useTLS","deviceId","browserName","browserVersion"]},"netflix.TestImmediate":{$schema:"http://json-schema.org/draft-07/schema#",title:"TestImmediate",description:"",ntl:{clientBehaviorConfig:{canBatch:!1,requiresEnhancedSecurity:!1}},type:"object",properties:{}},"netflix.TestRenderEnd":{$schema:"http://json-schema.org/draft-07/schema#",title:"TestRenderEnd",description:"",ntl:{clientBehaviorConfig:{canBatch:!0,requiresEnhancedSecurity:!1}},type:"object",properties:{viewName:{type:"string"},timestamp:{type:"number"},clientRenderTime:{type:"number"}},required:["viewName","timestamp","clientRenderTime"]},"netflix.TestRenderStart":{$schema:"http://json-schema.org/draft-07/schema#",title:"TestRenderStart",description:"",ntl:{clientBehaviorConfig:{canBatch:!0,requiresEnhancedSecurity:!1}},type:"object",properties:{viewName:{description:"",type:"string"},timestamp:{description:"",type:"number"}},required:["viewName","timestamp"]},"netflix.TitleRatingSelected":{$schema:"http://json-schema.org/draft-07/schema#",title:"TitleRatingSelected",description:"",ntl:{clientBehaviorConfig:{canBatch:!0,requiresEnhancedSecurity:!1}},type:"object",propertie